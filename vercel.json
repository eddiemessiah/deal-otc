{
  "version": 2,
  "builds": [
    { "src": "backend/core/server.js", "use": "@vercel/node" },
    { "src": "frontend/package.json", "use": "@vercel/next" }
  ],
  "rewrites": [
    { "source": "/api/backend/(.*)", "destination": "/backend/core/server.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
